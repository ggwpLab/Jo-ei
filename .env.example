# Jōei environment configuration — copy to .env and fill in.
#
#   cp .env.example .env
#
# docker-compose reads .env automatically and substitutes the values below into
# docker-compose.yaml. The real .env is gitignored — keep your secrets out of git.

# Admin console / API credentials (HTTP Basic). Without at least one user the
# console and /api/ are fail-closed (HTTP 503); the proxy data path stays open.
#
# Format: username:bcrypt-hash  (multiple users separated by ';')
#   JOEI_CONSOLE_AUTH_USERS=admin:$2a$10$...;alice:$2a$10$...
#
# Generate a hash (pick your own strong password):
#   printf '%s' 'change-me' | docker-compose run --rm -T jo-ei hashpw
#
# NOTE on '$': write the hash literally here. Unlike values placed *inline* in
# docker-compose.yaml (where a literal '$' must be doubled to '$$'), values in
# this .env file are NOT interpolated, so no escaping is needed.
JOEI_CONSOLE_AUTH_USERS=admin:$2a$10$REPLACE_WITH_A_REAL_BCRYPT_HASH
